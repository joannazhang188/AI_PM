# Server
PORT=4173

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Local Codex CLI
CODEX_CLI_PATH=codex
CODEX_CLI_MODEL=gpt-5.2
CODEX_CLI_WORKDIR=

# Codex Desktop Auth
# No env vars required. Uses ~/.codex/auth.json automatically if available.

# Codex proxy
# Assumes your local proxy is OpenAI-compatible.
CODEX_PROXY_BASE_URL=http://127.0.0.1:11434
CODEX_PROXY_MODEL=
CODEX_PROXY_API_STYLE=chat
CODEX_PROXY_API_KEY=
CODEX_PROXY_CHAT_PATH=/v1/chat/completions
CODEX_PROXY_RESPONSES_PATH=/v1/responses
